<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
  package="io.agora.vuihoc.agora_native">
    <application
        android:theme="@style/Theme.FlatAndroid"
       >

        <activity
            android:name="io.agora.flat.ui.activity.play.ClassRoomActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:theme="@style/Theme.FlatAndroid.Fullscreen"
            android:windowSoftInputMode="stateHidden|adjustNothing" />

        <activity
            android:name="io.agora.flat.ui.activity.playback.ReplayActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:theme="@style/Theme.FlatAndroid.Fullscreen" />

        <activity android:name="io.agora.flat.ui.activity.room.SubscribeRoomActivity" />
        <activity android:name="io.agora.flat.ui.activity.room.RoomDetailActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.FeedbackActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.AboutUsActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.LanguageActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.CallTestActivity" />
        <activity android:name="io.agora.flat.ui.activity.cloud.preview.PreviewActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.WebViewActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.DarkModeActivity" />
        <activity android:name="io.agora.flat.ui.activity.setting.EditNameActivity" />
        <activity android:name="io.agora.flat.ui.activity.dev.DevToolsActivity" />
        <activity android:name="io.agora.flat.ui.activity.dev.DevSettingsActivity" />
        <activity android:name="io.agora.flat.ui.activity.CallingCodeActivity" />

        <activity
            android:name="io.agora.flat.ui.activity.phone.PhoneBindActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name="io.agora.flat.ui.activity.register.RegisterActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name="io.agora.flat.ui.activity.password.PasswordResetActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name="io.agora.flat.ui.activity.LoginActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustNothing|stateHidden" />
        <activity
            android:name="io.agora.flat.ui.activity.dev.ComposeTestActivity"
            android:label="@string/title_activity_compose_test" />
        <activity
            android:name="io.agora.flat.ui.activity.home.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FlatAndroid.Launch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="flat-web-dev.whiteboard.agora.io"
                    android:scheme="https" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="web.flat.shengwang.cn"
                    android:scheme="https" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="web.flat.apprtc.cn"
                    android:scheme="https" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="flat-web.whiteboard.agora.io"
                    android:scheme="https" />
            </intent-filter>
        </activity>
        <activity
            android:name="io.agora.flat.ui.activity.setting.UserInfoActivity"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name="io.agora.flat.ui.activity.setting.AccountSecurityActivity"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name=".common.login.GithubEntryActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}">

            <intent-filter>
                <data android:scheme="x-agora-flat-client" />
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
            </intent-filter>
        </activity>
        <activity
            android:name="${applicationId}.wxapi.WXEntryActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            tools:node="merge" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <activity
            android:name="io.agora.flat.ui.activity.camera.CameraActivity"
            android:clearTaskOnLaunch="true"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize"
            android:exported="false"
            android:resizeableActivity="true"
            android:rotationAnimation="seamless"
            android:screenOrientation="fullUser"
            android:theme="@style/Theme.FlatAndroid.Camera"
            tools:targetApi="O" />
        <activity android:name="io.agora.flat.ui.activity.password.PasswordChangeActivity" />
        <activity android:name="io.agora.flat.ui.activity.password.PasswordSetActivity" />
        <activity android:name="io.agora.flat.ui.activity.bind.EmailBindActivity" />
        <activity android:name="io.agora.flat.ui.activity.register.RegisterProfileActivity" />
    </application>
</manifest>
